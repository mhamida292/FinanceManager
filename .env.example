# Copy to .env and fill in. .env is gitignored.

# --- Django ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=changeme

# DEBUG=true while testing directly. Flip to false once nginx is fronting HTTPS.
DJANGO_DEBUG=true

# Comma-separated. "*" is fine for the LAN-only test phase.
# Tighten to your real hostname once a reverse proxy fronts the app, e.g.
#   DJANGO_ALLOWED_HOSTS=your-domain.example.com,localhost
DJANGO_ALLOWED_HOSTS=*

# When the reverse proxy serves HTTPS, set to e.g. "https://your-domain.example.com".
# Blank is fine while DEBUG=true.
DJANGO_CSRF_TRUSTED_ORIGINS=

DJANGO_TIME_ZONE=America/New_York

# Host port the web container publishes on. Your nginx proxies to 127.0.0.1:<this>.
WEB_PORT=8000

# --- Field encryption ---
# 32-byte urlsafe-base64 Fernet key. Generate with:
#   python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEY=changeme

# --- Postgres ---
POSTGRES_DB=finance
POSTGRES_USER=finance
POSTGRES_PASSWORD=changeme

# Must match POSTGRES_* above. `db` resolves inside the compose network.
DATABASE_URL=postgres://finance:changeme@db:5432/finance

# --- Teller (mTLS bank aggregation) ---
# Sign up at https://teller.io to get an application ID and a sandbox/dev cert pair.
# Drop the cert + key PEM files in ./secrets/teller/ on the host; they get mounted
# read-only into the container at /run/secrets/teller/.
# Environment values: "sandbox" (fake banks/data, free), "development" (real banks,
# free up to 100 enrollments), or "production" (paid).
TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=sandbox
TELLER_CERT_PATH=/run/secrets/teller/cert.pem
TELLER_KEY_PATH=/run/secrets/teller/key.pem
