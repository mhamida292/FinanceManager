# Copy to .env and fill in. .env is gitignored.

# --- Django ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=changeme

# DEBUG=true while testing directly. Flip to false once nginx is fronting HTTPS.
DJANGO_DEBUG=true

# Comma-separated. "*" is fine for the LAN-only test phase.
# Tighten to "finance.momajlab.com" once nginx is fronting the app.
DJANGO_ALLOWED_HOSTS=*

# When nginx serves HTTPS for this app, set to "https://finance.momajlab.com".
# Blank is fine while DEBUG=true.
DJANGO_CSRF_TRUSTED_ORIGINS=

DJANGO_TIME_ZONE=America/New_York

# Host port the web container publishes on. Your nginx proxies to 127.0.0.1:<this>.
WEB_PORT=8000

# --- Field encryption ---
# 32-byte urlsafe-base64 Fernet key. Generate with:
#   python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEY=changeme

# --- Postgres ---
POSTGRES_DB=finance
POSTGRES_USER=finance
POSTGRES_PASSWORD=changeme

# Must match POSTGRES_* above. `db` resolves inside the compose network.
DATABASE_URL=postgres://finance:changeme@db:5432/finance
