# Copy to .env and fill in. .env is gitignored.

# --- Django ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=changeme

# For the initial "does it run" test, leave DEBUG=true.
# For the prod profile (Caddy + real domain), set DEBUG=false.
DJANGO_DEBUG=true

# Comma-separated. "*" is fine for the LAN-only test phase.
# Tighten to "finance.momajlab.com" once Caddy is fronting the app.
DJANGO_ALLOWED_HOSTS=*

# Only needed once Caddy fronts the app. Leave blank for the test phase.
DJANGO_CSRF_TRUSTED_ORIGINS=

DJANGO_TIME_ZONE=America/New_York

# Host port the web container publishes on. Override if 8000 is taken.
WEB_PORT=8000

# --- Postgres ---
POSTGRES_DB=finance
POSTGRES_USER=finance
POSTGRES_PASSWORD=changeme

# Must match POSTGRES_* above. `db` resolves inside the compose network.
DATABASE_URL=postgres://finance:changeme@db:5432/finance

# --- Caddy / Cloudflare (only used when `docker compose --profile prod up`) ---
# Scoped DNS-edit token for momajlab.com. Leave blank for the test phase.
CLOUDFLARE_API_TOKEN=
